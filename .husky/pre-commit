#!/bin/sh

# ============================================================
# Project-aware pre-commit hook
# Auto-discovers projects under apps/ and libs/ by looking for
# package.json files and runs lint for any that have staged
# changes. No manual edits needed when adding new projects.
# ============================================================

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FAILED=0

run_checks() {
  local project_dir="$1"

  if ! echo "$STAGED_FILES" | grep -q "^${project_dir}/"; then
    return 0
  fi

  echo ""
  echo "══ Checking ${project_dir} ══"

  if [ ! -d "${project_dir}/node_modules" ]; then
    echo "  ⚠ Skipping ${project_dir} (node_modules not installed, run: npm install)"
    return 0
  fi

  if ! cd "$project_dir" || ! node -e "const p=require('./package.json'); if(!p.scripts||!p.scripts.lint) process.exit(1)" 2>/dev/null; then
    echo "  ⚠ Skipping ${project_dir} (no lint script)"
    cd "$OLDPWD" 2>/dev/null
    return 0
  fi

  if npm run lint; then
    echo "  ✔ Lint passed"
  else
    echo "  ✘ Lint failed"
    FAILED=1
  fi

  cd "$OLDPWD"
}

# Auto-discover all package.json files under apps/ and libs/, excluding node_modules
PROJECT_DIRS=$(find apps libs -name 'package.json' -not -path '*/node_modules/*' 2>/dev/null | xargs -I{} dirname {} | sort -u)

for dir in $PROJECT_DIRS; do
  run_checks "$dir"
done

if [ "$FAILED" -ne 0 ]; then
  echo ""
  echo "✘ Pre-commit checks failed. Fix the issues above and try again."
  exit 1
fi

echo ""
echo "✔ All pre-commit checks passed!"
