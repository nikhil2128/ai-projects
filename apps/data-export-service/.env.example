# ── Application ────────────────────────────────────────────
NODE_ENV=development

# ── AWS Region ─────────────────────────────────────────────
AWS_REGION=us-east-1

# ── DynamoDB ───────────────────────────────────────────────
DYNAMODB_TABLE=export-jobs
# Optional: for local development with DynamoDB Local
# DYNAMODB_ENDPOINT=http://localhost:8000

# ── SQS ────────────────────────────────────────────────────
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/export-processing

# ── AWS S3 ─────────────────────────────────────────────────
# Optional: for local development with MinIO
# S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=data-exports
S3_FORCE_PATH_STYLE=false
# Presigned URL expiry in seconds (default 7 days)
S3_PRESIGN_EXPIRES=604800

# ── AWS SES (Email) ────────────────────────────────────────
SES_REGION=us-east-1
SES_FROM_EMAIL=exports@example.com

# ── Export Processor ───────────────────────────────────────
# Max pages to fetch (safety limit)
EXPORT_MAX_PAGES=10000
# Default page size if not provided in request
EXPORT_DEFAULT_PAGE_SIZE=500
