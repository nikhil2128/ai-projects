# ─── Server ──────────────────────────────────
PORT=3400
CORS_ORIGINS=*

# ─── PostgreSQL ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=click_analytics
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# ─── Redis ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_STREAM_KEY=clicks:stream
REDIS_CONSUMER_GROUP=click-workers
REDIS_MAX_STREAM_LEN=1000000

# ─── Worker ──────────────────────────────────
WORKER_BATCH_SIZE=500
WORKER_BATCH_TIMEOUT_MS=2000
WORKER_CONSUMER_ID=

# ─── In-Memory Buffer (fallback) ────────────
BUFFER_MAX_SIZE=100000
BUFFER_FLUSH_INTERVAL_MS=5000

# ─── Rate Limiting ──────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=1000
