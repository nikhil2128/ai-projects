# ─── Server ──────────────────────────────────
PORT=3400
CORS_ORIGINS=*

# ─── ClickHouse ──────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=click_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_REQUEST_TIMEOUT_MS=10000
CLICKHOUSE_MAX_OPEN_CONNECTIONS=20

# ─── Redis ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_STREAM_KEY=clicks:stream
REDIS_CONSUMER_GROUP=click-workers
REDIS_MAX_STREAM_LEN=1000000

# ─── Worker ──────────────────────────────────
WORKER_BATCH_SIZE=500
WORKER_BATCH_TIMEOUT_MS=2000
WORKER_CONSUMER_ID=

# ─── Ingestion Pipeline ──────────────────────
# clickhouse | kinesis-s3-clickhouse
INGESTION_MODE=clickhouse

# Required when INGESTION_MODE=kinesis-s3-clickhouse
AWS_REGION=us-east-1
KINESIS_STREAM_NAME=click-events-stream
KINESIS_ENDPOINT=

# ─── In-Memory Buffer (fallback) ────────────
BUFFER_MAX_SIZE=100000
BUFFER_FLUSH_INTERVAL_MS=5000

# ─── Rate Limiting ──────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=1000

# ─── Admin ──────────────────────────────────
# Master key for managing websites/API keys via /api/websites
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=
