# ── Application ────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (PostgreSQL) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=export_user
DB_PASSWORD=export_pass
DB_DATABASE=data_export_service

# ── Redis (BullMQ) ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── AWS S3 ─────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=data-exports
S3_FORCE_PATH_STYLE=true
# Presigned URL expiry in seconds (default 7 days)
S3_PRESIGN_EXPIRES=604800

# ── AWS SES (Email) ────────────────────────────────────────
SES_REGION=us-east-1
SES_FROM_EMAIL=exports@example.com

# ── Export Processor ───────────────────────────────────────
# Max pages to fetch (safety limit)
EXPORT_MAX_PAGES=10000
# Default page size if not provided in request
EXPORT_DEFAULT_PAGE_SIZE=500
# Queue concurrency
EXPORT_QUEUE_CONCURRENCY=5

# ── Rate Limiting ──────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=30
