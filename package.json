{
  "name": "ai-projects",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "libs/shared/*"
  ],
  "scripts": {
    "nx": "nx",
    "graph": "nx graph",
    "projects": "nx show projects",
    "lint": "nx run-many -t lint --all",
    "test": "nx run-many -t test --all",
    "build": "nx run-many -t build --all",
    "typecheck": "nx run-many -t typecheck --all",
    "dev": "nx run-many -t dev --all --parallel=5",
    "affected:lint": "nx affected -t lint",
    "affected:test": "nx affected -t test",
    "affected:build": "nx affected -t build",
    "affected:typecheck": "nx affected -t typecheck",
    "ci:affected": "nx affected -t lint typecheck test build",
    "ci:all": "nx run-many -t lint typecheck test build --all",
    "format:check": "nx format:check",
    "format:write": "nx format:write"
  },
  "devDependencies": {
    "@nx/js": "22.5.4",
    "@nx/workspace": "22.5.4",
    "nx": "22.5.4"
  }
}
